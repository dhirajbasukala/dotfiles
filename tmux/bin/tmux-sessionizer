#!/usr/bin/env bash

# Search paths for projects
SEARCH_PATHS=(
  ~/work
  # ~/work/dev
  # ~/work/learn
)
MAX_DEPTH=1

find_dirs() {
  tmux list-sessions -F "[TMUX] #{session_name}" 2>/dev/null

  for path in "${SEARCH_PATHS[@]}"; do
    [[ -d "$path" ]] || continue

    # Normal dirs (excluding __worktrees containers)
    find "$path" -mindepth 1 -maxdepth "$MAX_DEPTH" -type d \
      ! -name "*__worktrees"

    # One level deeper inside any __worktrees dir
    find "$path" -mindepth 2 -maxdepth "$((MAX_DEPTH + 1))" -type d \
      -path "*__worktrees/*" ! -name "*__worktrees"
  done
}

get_session_name() {
  local path="$1"
  # echo "$path" | sed -E 's/[^a-zA-Z0-9]/_/g'
  local name="${path##*/}"  # faster than basename
  local parent="${path%/*}" # faster than dirname
  parent="${parent##*/}"    # get just the last part

  if [[ "$parent" == *"__worktrees"* ]]; then
    local repo="${parent%__worktrees}"
    echo " ${repo} ${name}" | tr . _
  else
    echo " ${name}" | tr . _
  fi
}

# Pick a directory: use arg or fzf
if [[ -n "$1" ]]; then
  selected="$1"
else
  selected=$(find_dirs | fzf)
fi

[[ -z "$selected" ]] && exit 0

# If user picked an existing [TMUX] session, switch directly
if [[ "$selected" =~ ^\[TMUX\]\ (.+)$ ]]; then
  session_name="${BASH_REMATCH[1]}"
  if [[ -z "$TMUX" ]]; then
    tmux attach-session -t "$session_name"
  else
    tmux switch-client -t "$session_name"
  fi
  exit 0
fi

# New directory selected — derive session name from path
session_name=$(get_session_name "$selected")

# Start tmux if not running
if [[ -z "$TMUX" ]] && ! pgrep tmux &>/dev/null; then
  tmux new-session -ds "$session_name" -c "$selected"
fi

# Create session if it doesn't exist
if ! tmux list-sessions 2>/dev/null | grep -q "^$session_name:"; then
  tmux new-session -ds "$session_name" -c "$selected"
  if [[ -f "$selected/.tmux-sessionizer" ]]; then
    tmux send-keys -t "$session_name" "source $selected/.tmux-sessionizer" Enter
  elif [[ -f "$HOME/.tmux-sessionizer" ]]; then
    tmux send-keys -t "$session_name" "source $HOME/.tmux-sessionizer" Enter
  fi
fi

# Switch to the session
if [[ -z "$TMUX" ]]; then
  tmux attach-session -t "$session_name"
else
  tmux switch-client -t "$session_name"
fi
